# ════════════════════════════════════════════════════════
#  PHÚ YÊN 2026 — AI TRAVEL ASSISTANT — ENVIRONMENT
# ════════════════════════════════════════════════════════

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider (choose one)
# Option 1: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Option 2: Google Gemini (via OpenAI-compatible endpoint)
# GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps / Places
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Weather API (Open-Meteo is free, no key needed)
# WEATHER_API_KEY=optional_key_for_premium

# Database (SQLite for local, or connect to Google Sheets)
DATABASE_PATH=./data/travel_assistant.db

# Server
PORT=3000
NODE_ENV=development

# Optional: Google Sheets integration (for existing trip data)
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_KEY=path_to_service_account_json

# Multilingual support
DEFAULT_LANGUAGE=vi
SUPPORTED_LANGUAGES=vi,en,ja,ko,zh

# Trip Configuration
TRIP_NAME=Phú Yên 2026
TRIP_START=2026-05-23
TRIP_END=2026-05-27
TRIP_GROUP_SIZE=7
TRIP_CHILD_AGE=4